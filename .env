# ============================================
# RAG Backend — Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# All variables are prefixed with RAG_
# Loaded automatically by Pydantic BaseSettings in app/config.py
# ============================================

# --- Required ---
RAG_PINECONE_API_KEY=pcsk_4fyGgc_GwgLpqoooc2gq5HHR8jyJoS4MhQeC8jzsnPrtrU9jvYar18AEXBCtfZAigwDGhe

# --- Pinecone ---
RAG_PINECONE_INDEX_NAME=rag-index
RAG_PINECONE_ENVIRONMENT=us-east-1

# --- Embeddings (SentenceTransformers, runs locally) ---
RAG_EMBEDDING_MODEL_NAME=all-mpnet-base-v2

# --- LLM (Ollama, runs locally) ---
RAG_OLLAMA_BASE_URL=http://localhost:11434
RAG_OLLAMA_MODEL=phi3:mini

# --- Chunking defaults ---
RAG_DEFAULT_CHUNK_SIZE=1000
RAG_DEFAULT_CHUNK_OVERLAP=200

# --- RAG pipeline ---
RAG_CONFIDENCE_THRESHOLD=0.3
RAG_LLM_TIMEOUT=300
RAG_MAX_CHAT_HISTORY=1

# --- Upload limits ---
RAG_MAX_FILE_SIZE=52428800

# --- Database (document persistence) ---
RAG_DATABASE_URL=sqlite:///./rag_documents.db
